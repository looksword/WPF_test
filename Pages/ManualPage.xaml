                        <Ellipse Name="ABlowCloseOut" Width="10" Height="10" Fill="Gray"
                                 Stroke="DarkGray" StrokeThickness="1"/>
                        <TextBlock Name="ABlowCloseOutText" Text="off" FontSize="12"  Foreground="#FFFFFF"
                                   VerticalAlignment="Center" Margin="2,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Viewbox>

        <!-- 2-4：机箱照明 -->
        <Viewbox Grid.Row="1" Grid.Column="3" Margin="5" Stretch="Uniform" StretchDirection="Both">
            <Border BorderBrush="#569CD6" BorderThickness="2" CornerRadius="4" 
                    MinWidth="150" MinHeight="120">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" 
                            Background="#569CD6" Margin="-5,-5,-5,0" CornerRadius="4,4,0,0" Height="26">
                        <TextBlock Text="机箱照明" FontSize="16" FontWeight="Bold" 
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="操作" FontSize="14" FontWeight="Bold" Foreground="#FFFFFF"
                               HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,2"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="输入" FontSize="14" FontWeight="Bold" Foreground="#FFFFFF"
                               HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,2"/>
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="输出" FontSize="14" FontWeight="Bold" Foreground="#FFFFFF"
                               HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,2"/>

                    <Button Grid.Row="2" Grid.Column="0" Content="开灯" Height="24" FontSize="16"
                            Background="#4CAF50" Foreground="White" HorizontalAlignment="Stretch" VerticalAlignment="Center" Margin="2"/>

                    <TextBlock Grid.Row="2" Grid.Column="1" Text="-" FontSize="14" 
                               HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Gray"/>

                    <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Ellipse Name="LightOpenOut" Width="10" Height="10" Fill="Gray"
                                 Stroke="DarkGray" StrokeThickness="1"/>
                        <TextBlock Name="LightOpenOutText" Text="off" FontSize="12"  Foreground="#FFFFFF"
                                   VerticalAlignment="Center" Margin="2,0"/>
                    </StackPanel>

                    <Button Grid.Row="3" Grid.Column="0" Content="关灯" Height="24" FontSize="16"
                            Background="#F44336" Foreground="White" HorizontalAlignment="Stretch" VerticalAlignment="Center" Margin="2"/>

                    <TextBlock Grid.Row="3" Grid.Column="1" Text="-" FontSize="14" 
                               HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Gray"/>

                    <StackPanel Grid.Row="3" Grid.Column="2" Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Ellipse Name="LightCloseOut" Width="10" Height="10" Fill="Gray"
                                 Stroke="DarkGray" StrokeThickness="1"/>
                        <TextBlock Name="LightCloseOutText" Text="off" FontSize="12"  Foreground="#FFFFFF"
                                   VerticalAlignment="Center" Margin="2,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Viewbox>

    </Grid>
</UserControl>