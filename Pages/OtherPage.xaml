<UserControl x:Class="WPF_test.Pages.OtherPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== 上方：预留按钮区域 ===== -->
        <GroupBox Grid.Row="0" Header="功能按钮 (预留)" FontSize="14" FontWeight="Bold" Margin="0,0,0,10">
            <WrapPanel Margin="8">
                <Button Content="预留按钮 1" Width="110" Height="40" FontSize="14" Margin="4"
                        Background="#607D8B" Foreground="White"/>
                <Button Content="预留按钮 2" Width="110" Height="40" FontSize="14" Margin="4"
                        Background="#607D8B" Foreground="White"/>
                <Button Content="预留按钮 3" Width="110" Height="40" FontSize="14" Margin="4"
                        Background="#607D8B" Foreground="White"/>
                <Button Content="预留按钮 4" Width="110" Height="40" FontSize="14" Margin="4"
                        Background="#607D8B" Foreground="White"/>
                <Button Content="预留按钮 5" Width="110" Height="40" FontSize="14" Margin="4"
                        Background="#607D8B" Foreground="White"/>
                <Button Content="预留按钮 6" Width="110" Height="40" FontSize="14" Margin="4"
                        Background="#607D8B" Foreground="White"/>
                <Button Content="预留按钮 7" Width="110" Height="40" FontSize="14" Margin="4"
                        Background="#607D8B" Foreground="White"/>
                <Button Content="预留按钮 8" Width="110" Height="40" FontSize="14" Margin="4"
                        Background="#607D8B" Foreground="White"/>
            </WrapPanel>
        </GroupBox>

        <!-- ===== 中间：预留内容 ===== -->
        <GroupBox Grid.Row="1" Header="扩展区域" FontSize="14" FontWeight="Bold">
            <TextBlock Text="此区域预留用于扩展功能"
                       FontSize="16" Foreground="Gray"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </GroupBox>

        <!-- ===== 下方：生产参数按钮 ===== -->
        <GroupBox Grid.Row="2" Header="生产参数" FontSize="14" FontWeight="Bold" Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="8">
                <Button Content="参 数 设 定" Width="160" Height="50" FontSize="16"
                        Margin="10" Background="#4CAF50" Foreground="White"/>
                <Button Content="功 能 旋 转" Width="160" Height="50" FontSize="16"
                        Margin="10" Background="#FF9800" Foreground="White"/>
            </StackPanel>
        </GroupBox>
    </Grid>
</UserControl>
