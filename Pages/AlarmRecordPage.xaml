<UserControl x:Class="WPF_test.Pages.AlarmRecordPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧：报警记录列表 -->
        <GroupBox Grid.Column="0" Header="报警记录" FontSize="24" FontWeight="Bold" Foreground="#FFFFFF">
            <DataGrid Margin="5" AutoGenerateColumns="False" IsReadOnly="True"
                      HeadersVisibility="Column" FontSize="13">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="序号" Width="50"/>
                    <DataGridTextColumn Header="时间" Width="170"/>
                    <DataGridTextColumn Header="报警内容" Width="*"/>
                    <DataGridTextColumn Header="级别" Width="60"/>
                </DataGrid.Columns>

            </DataGrid>
        </GroupBox>

        <!-- 右侧：操作按钮 -->
        <StackPanel Grid.Column="1" Margin="10,0,0,0" Width="130">
            <TextBlock Text="报警记录" FontSize="24" FontWeight="Bold"  Foreground="#FFFFFF"
                       HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <Button Content="上一页" Height="45" FontSize="24" Margin="0,5"
                    Background="#2196F3" Foreground="White"/>
            <Button Content="下一页" Height="45" FontSize="24" Margin="0,5"
                    Background="#2196F3" Foreground="White"/>

            <Separator Margin="0,15"/>

            <Button Content="报警清空" Height="45" FontSize="24" Margin="0,5"
                    Background="#F44336" Foreground="White"/>

            <Separator Margin="0,15"/>

            <GroupBox Header="统计" FontSize="20" Margin="0,5"  Foreground="#FFFFFF">
                <StackPanel Margin="5">
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <TextBlock Text="紧急:" FontSize="24"/>
                        <TextBlock Text="0" FontSize="24" FontWeight="Bold"
                                   Foreground="Red" Margin="5,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <TextBlock Text="警告:" FontSize="24"/>
                        <TextBlock Text="3" FontSize="24" FontWeight="Bold"
                                   Foreground="Orange" Margin="5,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <TextBlock Text="提示:" FontSize="24"/>
                        <TextBlock Text="12" FontSize="24" FontWeight="Bold"
                                   Foreground="Gray" Margin="5,0"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>
        </StackPanel>
    </Grid>
</UserControl>
