<UserControl x:Class="WPF_test.Pages.IOPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignHeight="450" d:DesignWidth="800"
        Background="#F5F5F5"
        Unloaded="UserControl_Unloaded">

    <UserControl.Resources>
        <!-- 指示灯样式 -->
        <Style x:Key="IndicatorLight" TargetType="Ellipse">
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="True">
                    <Setter Property="Fill" Value="#4CAF50"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#4CAF50" Opacity="0.6"/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="False">
                    <Setter Property="Fill" Value="#BDBDBD"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="4" ShadowDepth="0" Color="#666" Opacity="0.3"/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- IO显示区域 -->
        <Border Grid.Column="0" Background="White" Margin="10" CornerRadius="5" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 4列16行IO网格 -->
                <ItemsControl Grid.Row="0" ItemsSource="{Binding IOItems}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="4" Rows="16" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#E0E0E0" BorderThickness="0,0,1,1" 
                                Background="Transparent" Margin="1">
                                <Grid Margin="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" MinWidth="50"/>
                                        <ColumnDefinition Width="Auto" MinWidth="20"/>
                                        <ColumnDefinition Width="*" MinWidth="30"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- 地址 -->
                                    <TextBlock Grid.Column="0" Text="{Binding Address}" 
                                           FontFamily="Consolas" FontSize="12" 
                                           VerticalAlignment="Center" HorizontalAlignment="Center"
                                           FontWeight="SemiBold"/>
                                    <!-- 状态灯 -->
                                    <Ellipse Grid.Column="1" Style="{StaticResource IndicatorLight}"
                                         VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <!-- 备注 -->
                                    <TextBlock Grid.Column="2" Text="{Binding Remark}" 
                                           FontSize="11" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding Remark}"
                                           Margin="2,0,0,0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <!-- 右侧翻页控制 -->
        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,15,0" Width="85">
            <!-- 当前页面显示 -->
            <Border Background="#607D8B" CornerRadius="5" Padding="10,15" Margin="0,0,0,15">
                <TextBlock Text="{Binding CurrentPage}" FontSize="16" FontWeight="Bold" 
                           Foreground="White" HorizontalAlignment="Center"/>
            </Border>

            <!-- 上一页按钮 -->
            <Button Margin="0,5" Padding="10,10" 
                    Background="#E0E0E0" BorderThickness="0" Cursor="Hand"
                    Command="{Binding PrevPageCommand}">
                <StackPanel>
                    <TextBlock Text="▲" FontSize="18" HorizontalAlignment="Center"/>
                    <TextBlock Text="上一页" FontSize="12" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#E0E0E0"/>
                        <Setter Property="Foreground" Value="#333"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#BDBDBD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#9E9E9E"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <!-- 下一页按钮 -->
            <Button Margin="0,5" Padding="10,10" 
                    Background="#E0E0E0" BorderThickness="0" Cursor="Hand"
                    Command="{Binding NextPageCommand}">
                <StackPanel>
                    <TextBlock Text="▼" FontSize="18" HorizontalAlignment="Center"/>
                    <TextBlock Text="下一页" FontSize="12" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#E0E0E0"/>
                        <Setter Property="Foreground" Value="#333"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#BDBDBD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#9E9E9E"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>