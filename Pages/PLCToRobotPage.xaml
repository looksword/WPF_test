<UserControl x:Class="WPF_test.Pages.PLCToRobotPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             Background="#F5F5F5"
             HorizontalContentAlignment="Stretch"
             VerticalContentAlignment="Stretch">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 标题行 -->
            <RowDefinition Height="Auto"/>
            <!-- 连接设置 -->
            <RowDefinition Height="*"/>
            <!-- 读取保持寄存器（占用剩余可用空间的一半） -->
            <RowDefinition Height="*"/>
            <!-- 写入保持寄存器（占用另一半） -->
        </Grid.RowDefinitions>

        <!-- 标题 & 关闭按钮 -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Modbus TCP 通讯测试" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="✕" FontSize="20" Foreground="Black" Background="Transparent" 
                    BorderThickness="0" Cursor="Hand" VerticalAlignment="Center" 
                    Click="CloseButton_Click" Padding="5,0"/>
        </Grid>

        <!-- 连接设置 -->
        <GroupBox Grid.Row="1" Header="连接设置" Margin="0,0,0,10">
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="IP地址：" VerticalAlignment="Center" Margin="5"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Ip, UpdateSourceTrigger=PropertyChanged}" Margin="5" HorizontalAlignment="Stretch"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="端口：" VerticalAlignment="Center" Margin="5"/>
                <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" Margin="5" HorizontalAlignment="Stretch"/>
                <StackPanel Grid.Row="0" Grid.Column="4" Orientation="Horizontal" Margin="10,0,0,0" VerticalAlignment="Center">
                    <Button Content="连接" Width="80" Height="30" Background="#4CAF50" Foreground="White" BorderThickness="0"
                            Command="{Binding ConnectCommand}"/>
                    <Button Content="断开" Width="80" Height="30" Margin="10,0,0,0" Background="#F44336" Foreground="White" BorderThickness="0"
                            Command="{Binding DisconnectCommand}"/>
                </StackPanel>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="状态：" VerticalAlignment="Center" Margin="5"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="4" Text="{Binding StatusText}" 
                           VerticalAlignment="Center" Margin="5" FontWeight="Bold">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="Red"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                    <Setter Property="Foreground" Value="Green"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </GroupBox>

        <!-- 读取保持寄存器 -->
        <GroupBox Grid.Row="2" Header="读取保持寄存器" Margin="0,0,0,10">
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 输入行 -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="站号：" VerticalAlignment="Center" Margin="5"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ReadSlaveId, UpdateSourceTrigger=PropertyChanged}" Margin="5" HorizontalAlignment="Stretch"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="起始地址：" VerticalAlignment="Center" Margin="5"/>
                <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding ReadAddress, UpdateSourceTrigger=PropertyChanged}" Margin="5" HorizontalAlignment="Stretch"/>
                <TextBlock Grid.Row="0" Grid.Column="4" Text="数量：" VerticalAlignment="Center" Margin="5"/>
                <TextBox Grid.Row="0" Grid.Column="5" Text="{Binding ReadCount, UpdateSourceTrigger=PropertyChanged}" Margin="5" HorizontalAlignment="Stretch"/>
                <Button Grid.Row="0" Grid.Column="6" Content="读取" Width="80" Height="30" 
                        Background="#2196F3" Foreground="White" BorderThickness="0"
                        Command="{Binding ReadCommand}" VerticalAlignment="Center"/>

                <!-- 结果行 -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="结果：" VerticalAlignment="Top" Margin="5"/>
                <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="6" Text="{Binding ReadResult}" 
                         Margin="5" TextWrapping="Wrap" AcceptsReturn="True" 
                         VerticalScrollBarVisibility="Auto" IsReadOnly="True" Background="#E0E0E0"
                         VerticalAlignment="Stretch" MinHeight="40"/>
            </Grid>
        </GroupBox>

        <!-- 写入保持寄存器 -->
        <GroupBox Grid.Row="3" Header="写入保持寄存器">
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 输入行 -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="站号：" VerticalAlignment="Center" Margin="5"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding WriteSlaveId, UpdateSourceTrigger=PropertyChanged}" Margin="5" HorizontalAlignment="Stretch"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="起始地址：" VerticalAlignment="Center" Margin="5"/>
                <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding WriteAddress, UpdateSourceTrigger=PropertyChanged}" Margin="5" HorizontalAlignment="Stretch"/>
                <TextBlock Grid.Row="0" Grid.Column="4" Text="数值（逗号分隔）：" VerticalAlignment="Center" Margin="5"/>
                <TextBox Grid.Row="0" Grid.Column="5" Text="{Binding WriteValues, UpdateSourceTrigger=PropertyChanged}" Margin="5" HorizontalAlignment="Stretch"/>
                <Button Grid.Row="0" Grid.Column="6" Content="写入" Width="80" Height="30" 
                        Background="#FF9800" Foreground="White" BorderThickness="0"
                        Command="{Binding WriteCommand}" VerticalAlignment="Center"/>

                <!-- 说明 -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="说明：" VerticalAlignment="Center" Margin="5"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="5" Text="数值用英文逗号分隔，如: 1,2,3" VerticalAlignment="Center" Margin="5" Foreground="Gray"/>

                <!-- 写入结果 -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="写入结果：" VerticalAlignment="Top" Margin="5"/>
                <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="5" Text="{Binding WriteResult}" 
                         Margin="5" TextWrapping="Wrap" AcceptsReturn="True" 
                         VerticalScrollBarVisibility="Auto" IsReadOnly="True" Background="#E0E0E0"
                         VerticalAlignment="Stretch" MinHeight="30"/>
            </Grid>
        </GroupBox>
    </Grid>
</UserControl>