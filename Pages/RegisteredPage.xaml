<UserControl x:Class="WPF_test.Pages.RegisteredPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="在  籍  状  态" FontSize="22" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,10,0,20"/>

        <!-- 在籍状态卡片区域 -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 卡片 1 -->
            <GroupBox Grid.Row="0" Grid.Column="0" Header="轴 1" FontSize="14" FontWeight="Bold"
                      Margin="5" BorderBrush="#569CD6" BorderThickness="2">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
                        <TextBlock Text="在籍:" FontSize="14" VerticalAlignment="Center"/>
                        <Ellipse Width="20" Height="20" Fill="LimeGreen" Margin="8,0"
                                 Stroke="DarkGreen" StrokeThickness="1"/>
                        <TextBlock Text="正常" FontSize="14" FontWeight="Bold" Foreground="Green"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Grid.Row="1" Text="运行时间: 128h" FontSize="13"
                               HorizontalAlignment="Center" Margin="0,5"/>

                    <Button Grid.Row="2" Content="查看详情" Width="90" Height="30" FontSize="13" Margin="0,5"/>
                </Grid>
            </GroupBox>

            <!-- 卡片 2 -->
            <GroupBox Grid.Row="0" Grid.Column="1" Header="轴 2" FontSize="14" FontWeight="Bold"
                      Margin="5" BorderBrush="#569CD6" BorderThickness="2">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
                        <TextBlock Text="在籍:" FontSize="14" VerticalAlignment="Center"/>
                        <Ellipse Width="20" Height="20" Fill="LimeGreen" Margin="8,0"
                                 Stroke="DarkGreen" StrokeThickness="1"/>
                        <TextBlock Text="正常" FontSize="14" FontWeight="Bold" Foreground="Green"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Grid.Row="1" Text="运行时间: 256h" FontSize="13"
                               HorizontalAlignment="Center" Margin="0,5"/>

                    <Button Grid.Row="2" Content="查看详情" Width="90" Height="30" FontSize="13" Margin="0,5"/>
                </Grid>
            </GroupBox>

            <!-- 卡片 3 -->
            <GroupBox Grid.Row="0" Grid.Column="2" Header="轴 3" FontSize="14" FontWeight="Bold"
                      Margin="5" BorderBrush="#569CD6" BorderThickness="2">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
                        <TextBlock Text="在籍:" FontSize="14" VerticalAlignment="Center"/>
                        <Ellipse Width="20" Height="20" Fill="Gold" Margin="8,0"
                                 Stroke="DarkGoldenrod" StrokeThickness="1"/>
                        <TextBlock Text="警告" FontSize="14" FontWeight="Bold" Foreground="Orange"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Grid.Row="1" Text="运行时间: 64h" FontSize="13"
                               HorizontalAlignment="Center" Margin="0,5"/>

                    <Button Grid.Row="2" Content="查看详情" Width="90" Height="30" FontSize="13" Margin="0,5"/>
                </Grid>
            </GroupBox>

            <!-- 卡片 4 -->
            <GroupBox Grid.Row="1" Grid.Column="0" Header="刀具寿命" FontSize="14" FontWeight="Bold"
                      Margin="5" BorderBrush="#569CD6" BorderThickness="2">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
                        <TextBlock Text="在籍:" FontSize="14" VerticalAlignment="Center"/>
                        <Ellipse Width="20" Height="20" Fill="LimeGreen" Margin="8,0"
                                 Stroke="DarkGreen" StrokeThickness="1"/>
                        <TextBlock Text="正常" FontSize="14" FontWeight="Bold" Foreground="Green"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Grid.Row="1" Text="T01: 85% | T12: 60%" FontSize="13"
                               HorizontalAlignment="Center" Margin="0,5"/>

                    <Button Grid.Row="2" Content="查看详情" Width="90" Height="30" FontSize="13" Margin="0,5"/>
                </Grid>
            </GroupBox>

            <!-- 卡片 5 -->
            <GroupBox Grid.Row="1" Grid.Column="1" Header="润滑系统" FontSize="14" FontWeight="Bold"
                      Margin="5" BorderBrush="#569CD6" BorderThickness="2">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
                        <TextBlock Text="在籍:" FontSize="14" VerticalAlignment="Center"/>
                        <Ellipse Width="20" Height="20" Fill="LimeGreen" Margin="8,0"
                                 Stroke="DarkGreen" StrokeThickness="1"/>
                        <TextBlock Text="正常" FontSize="14" FontWeight="Bold" Foreground="Green"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Grid.Row="1" Text="油位: 78%" FontSize="13"
                               HorizontalAlignment="Center" Margin="0,5"/>

                    <Button Grid.Row="2" Content="查看详情" Width="90" Height="30" FontSize="13" Margin="0,5"/>
                </Grid>
            </GroupBox>

            <!-- 卡片 6 -->
            <GroupBox Grid.Row="1" Grid.Column="2" Header="气压系统" FontSize="14" FontWeight="Bold"
                      Margin="5" BorderBrush="#569CD6" BorderThickness="2">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
                        <TextBlock Text="在籍:" FontSize="14" VerticalAlignment="Center"/>
                        <Ellipse Width="20" Height="20" Fill="LimeGreen" Margin="8,0"
                                 Stroke="DarkGreen" StrokeThickness="1"/>
                        <TextBlock Text="正常" FontSize="14" FontWeight="Bold" Foreground="Green"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Grid.Row="1" Text="气压: 0.6MPa" FontSize="13"
                               HorizontalAlignment="Center" Margin="0,5"/>

                    <Button Grid.Row="2" Content="查看详情" Width="90" Height="30" FontSize="13" Margin="0,5"/>
                </Grid>
            </GroupBox>

            <!-- 底部汇总按钮 -->
            <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                        Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                <Button Content="刷新状态" Width="110" Height="38" FontSize="14" Margin="5"
                        Background="#2196F3" Foreground="White"/>
                <Button Content="导出报告" Width="110" Height="38" FontSize="14" Margin="5"/>
                <Button Content="在籍设定" Width="110" Height="38" FontSize="14" Margin="5"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
