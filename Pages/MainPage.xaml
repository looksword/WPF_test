<UserControl x:Class="WPF_test.Pages.MainPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <!-- 共享的刀具数据源 -->
        <x:Array x:Key="ToolList" Type="sys:String">
            <sys:String>--</sys:String>
            <sys:String>01 - 铣刀</sys:String>
            <sys:String>02 - 钻头</sys:String>
            <sys:String>03 - 铰刀</sys:String>
            <sys:String>04 - 丝锥</sys:String>
            <sys:String>05 - 镗刀</sys:String>
            <sys:String>06 - 车刀</sys:String>
            <sys:String>07 - 铣刀</sys:String>
            <sys:String>08 - 钻头</sys:String>
            <sys:String>09 - 铰刀</sys:String>
            <sys:String>10 - 丝锥</sys:String>
            <sys:String>11 - 镗刀</sys:String>
            <sys:String>12 - 车刀</sys:String>
            <sys:String>13 - 铣刀</sys:String>
            <sys:String>14 - 钻头</sys:String>
            <sys:String>15 - 铰刀</sys:String>
        </x:Array>

        <!-- 单元格TextBlock样式 -->
        <Style x:Key="TextBlockStyle1" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="2,0,0,0"/>
        </Style>
        <Style x:Key="TextBlockStyle2" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style x:Key="TextBlockStyle3" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Bottom"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>

        <!-- 单元格Border样式 -->
        <Style x:Key="ToolCellBorderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="#666666"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Background" Value="#F8F8F8"/>
        </Style>

        <!-- 刀具标签样式 - 字体调大 -->
        <Style x:Key="ToolLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <!-- ComboBox样式 - 字体调大 -->
        <Style x:Key="ToolComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="ItemsSource" Value="{StaticResource ToolList}"/>
            <Setter Property="SelectedIndex" Value="0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#888888"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="IsEditable" Value="False"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="MinWidth" Value="60"/>
            <Setter Property="MinHeight" Value="40"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="5">
        <Grid x:Name="MainContentGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" MinWidth="300"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="1*" MinWidth="400"/>
            </Grid.ColumnDefinitions>

            <!-- ===== 左侧：5×5 料架状态 ===== -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Row="0" Margin="5,0,5,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="料架状态显示" FontSize="36" FontWeight="Bold" VerticalAlignment="Center" Foreground="#1a5a1c"/>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="10,2,0,2">
                            <TextBlock Text="0.0" FontSize="20" FontWeight="SemiBold" Foreground="#FFFFFF" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="左CNC加工时长" FontSize="20" FontWeight="SemiBold" Foreground="#FFFFFF" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="10,2,0,2">
                            <TextBlock Text="ABL" FontSize="20" FontWeight="SemiBold" Foreground="#FFFFFF" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox Text="0" Width="40" Height="28" FontSize="13" VerticalContentAlignment="Center" BorderBrush="#5a7a9a" BorderThickness="1"/>
                            <TextBlock Text="A寻址" FontSize="20" FontWeight="SemiBold" Foreground="#FFFFFF" VerticalAlignment="Center" Margin="8,0,8,0"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="10,2,0,2">
                            <TextBlock Text="0.0" FontSize="20" FontWeight="SemiBold" Foreground="#FFFFFF" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="右CNC加工时长" FontSize="20" FontWeight="SemiBold" Foreground="#FFFFFF" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="10,2,0,2">
                            <TextBlock Text="BBL" FontSize="20" FontWeight="SemiBold" Foreground="#FFFFFF" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox Text="4" Width="40" Height="28" FontSize="13" VerticalContentAlignment="Center" BorderBrush="#5a7a9a" BorderThickness="1"/>
                            <TextBlock Text="B寻址" FontSize="20" FontWeight="SemiBold" Foreground="#FFFFFF" VerticalAlignment="Center" Margin="8,0,8,0"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <GroupBox Grid.Row="1" Header="" FontSize="16" FontWeight="Bold">
                    <Grid Margin="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 25 个料架位置 -->
                        <!-- 第1行 -->
                        <Border x:Name="Rack_0_0" Grid.Row="0" Grid.Column="0" Margin="3"
                            Background="Yellow" BorderBrush="Gray" BorderThickness="1" CornerRadius="3">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="1" Style="{StaticResource TextBlockStyle1}"/>
                                <TextBlock Grid.Row="1" Text="料A" Style="{StaticResource TextBlockStyle2}"/>
                                <TextBlock Grid.Row="2" Text="已分配" Style="{StaticResource TextBlockStyle3}"/>
                            </Grid>
                        </Border>
                        <Border x:Name="Rack_0_1" Grid.Row="0" Grid.Column="1" Margin="3"
                            Background="Yellow" BorderBrush="Gray" BorderThickness="1" CornerRadius="3">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="2" Style="{StaticResource TextBlockStyle1}"/>
                                <TextBlock Grid.Row="1" Text="料B" Style="{StaticResource TextBlockStyle2}"/>
                                <TextBlock Grid.Row="2" Text="已分配" Style="{StaticResource TextBlockStyle3}"/>
                            </Grid>
                        </Border>
                        <Border x:Name="Rack_0_2" Grid.Row="0" Grid.Column="2" Margin="3"
                            Background="Yellow" BorderBrush="Gray" BorderThickness="1" CornerRadius="3">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="3" Style="{StaticResource TextBlockStyle1}"/>
                                <TextBlock Grid.Row="1" Text="料C" Style="{StaticResource TextBlockStyle2}"/>
                                <TextBlock Grid.Row="2" Text="待分配" Style="{StaticResource TextBlockStyle3}"/>
                            </Grid>
                        </Border>
                        <Border x:Name="Rack_0_3" Grid.Row="0" Grid.Column="3" Margin="3"
                            Background="Yellow" BorderBrush="Gray" BorderThickness="1" CornerRadius="3">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="4" Style="{StaticResource TextBlockStyle1}"/>
                                <TextBlock Grid.Row="1" Text="料D" Style="{StaticResource TextBlockStyle2}"/>
                                <TextBlock Grid.Row="2" Text="已分配" Style="{StaticResource TextBlockStyle3}"/>
                            </Grid>
                        </Border>
                        <Border x:Name="Rack_0_4" Grid.Row="0" Grid.Column="4" Margin="3"
                            Background="Red" BorderBrush="Gray" BorderThickness="1" CornerRadius="3">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="5" Style="{StaticResource TextBlockStyle1}"/>
                                <TextBlock Grid.Row="1" Text="空" Style="{StaticResource TextBlockStyle2}"/>
                                <TextBlock Grid.Row="2" Text="待分配" Style="{StaticResource TextBlockStyle3}"/>
                            </Grid>
                        </Border>

                        <!-- 第2行 -->
                        <Border x:Name="Rack_1_0" Grid.Row="1" Grid.Column="0" Margin="3"
                            Background="Yellow" BorderBrush="Gray" BorderThickness="1" CornerRadius="3">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="6" Style="{StaticResource TextBlockStyle1}"/>
                                <TextBlock Grid.Row="1" Text="料E" Style="{StaticResource TextBlockStyle2}"/>
                                <TextBlock Grid.Row="2" Text="已分配" Style="{StaticResource TextBlockStyle3}"/>
                            </Grid>
                        </Border>
                        <Border x:Name="Rack_1_1" Grid.Row="1" Grid.Column="1" Margin="3"
                            Background="Yellow" BorderBrush="Gray" BorderThickness="1" CornerRadius="3">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="7" Style="{StaticResource TextBlockStyle1}"/>
                                <TextBlock Grid.Row="1" Text="料F" Style="{StaticResource TextBlockStyle2}"/>
                                <TextBlock Grid.Row="2" Text="已分配" Style="{StaticResource TextBlockStyle3}"/>
                            </Grid>
                        </Border>
                        <Border x:Name="Rack_1_2" Grid.Row="1" Grid.Column="2" Margin="3"
                            Background="Red" BorderBrush="Gray" BorderThickness="1" CornerRadius="3">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="8" Style="{StaticResource TextBlockStyle1}"/>
                                <TextBlock Grid.Row="1" Text="空" Style="{StaticResource TextBlockStyle2}"/>
                                <TextBlock Grid.Row="2" Text="待分配" Style="{StaticResource TextBlockStyle3}"/>
                            </Grid>
                        </Border>
                        <Border x:Name="Rack_1_3" Grid.Row="1" Grid.Column="3" Margin="3"
                            Background="Yellow" BorderBrush="Gray" BorderThickness="1" CornerRadius="3">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="9" Style="{StaticResource TextBlockStyle1}"/>
                                <TextBlock Grid.Row="1" Text="料G" Style="{StaticResource TextBlockStyle2}"/>
                                <TextBlock Grid.Row="2" Text="待分配" Style="{StaticResource TextBlockStyle3}"/>
                            </Grid>
                        </Border>
                        <Border x:Name="Rack_1_4" Grid.Row="1" Grid.Column="4" Margin="3"
                            Background="Yellow" BorderBrush="Gray" BorderThickness="1" CornerRadius="3">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="10" Style="{StaticResource TextBlockStyle1}"/>
                                <TextBlock Grid.Row="1" Text="料H" Style="{StaticResource TextBlockStyle2}"/>
                                <TextBlock Grid.Row="2" Text="已分配" Style="{StaticResource TextBlockStyle3}"/>
                            </Grid>
                        </Border>

                        <!-- 第3行 -->
                        <Border x:Name="Rack_2_0" Grid.Row="2" Grid.Column="0" Margin="3"
                            Background="Red" BorderBrush="Gray" BorderThickness="1" CornerRadius="3">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="11" Style="{StaticResource TextBlockStyle1}"/>
                                <TextBlock Grid.Row="1" Text="空" Style="{StaticResource TextBlockStyle2}"/>
                                <TextBlock Grid.Row="2" Text="待分配" Style="{StaticResource TextBlockStyle3}"/>
                            </Grid>
                        </Border>
                        <Border x:Name="Rack_2_1" Grid.Row="2" Grid.Column="1" Margin="3"
                            Background="Yellow" BorderBrush="Gray" BorderThickness="1" CornerRadius="3">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="12" Style="{StaticResource TextBlockStyle1}"/>
                                <TextBlock Grid.Row="1" Text="料I" Style="{StaticResource TextBlockStyle2}"/>
                                <TextBlock Grid.Row="2" Text="已分配" Style="{StaticResource TextBlockStyle3}"/>
                            </Grid>
                        </Border>
                        <Border x:Name="Rack_2_2" Grid.Row="2" Grid.Column="2" Margin="3"
                            Background="Yellow" BorderBrush="Gray" BorderThickness="1" CornerRadius="3">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="13" Style="{StaticResource TextBlockStyle1}"/>
                                <TextBlock Grid.Row="1" Text="料J" Style="{StaticResource TextBlockStyle2}"/>
                                <TextBlock Grid.Row="2" Text="待分配" Style="{StaticResource TextBlockStyle3}"/>
                            </Grid>
                        </Border>
                        <Border x:Name="Rack_2_3" Grid.Row="2" Grid.Column="3" Margin="3"
                            Background="Yellow" BorderBrush="Gray" BorderThickness="1" CornerRadius="3">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="14" Style="{StaticResource TextBlockStyle1}"/>
                                <TextBlock Grid.Row="1" Text="料K" Style="{StaticResource TextBlockStyle2}"/>
                                <TextBlock Grid.Row="2" Text="已分配" Style="{StaticResource TextBlockStyle3}"/>
                            </Grid>
                        </Border>
                        <Border x:Name="Rack_2_4" Grid.Row="2" Grid.Column="4" Margin="3"
                            Background="Red" BorderBrush="Gray" BorderThickness="1" CornerRadius="3">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="15"  Style="{StaticResource TextBlockStyle1}"/>
                                <TextBlock Grid.Row="1" Text="空"  Style="{StaticResource TextBlockStyle2}"/>
                                <TextBlock Grid.Row="2" Text="待分配"  Style="{StaticResource TextBlockStyle3}"/>
                            </Grid>
                        </Border>

                        <!-- 第4行 -->
                        <Border x:Name="Rack_3_0" Grid.Row="3" Grid.Column="0" Margin="3"
                            Background="Yellow" BorderBrush="Gray" BorderThickness="1" CornerRadius="3">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="16"  Style="{StaticResource TextBlockStyle1}"/>
                                <TextBlock Grid.Row="1" Text="料L"  Style="{StaticResource TextBlockStyle2}"/>
                                <TextBlock Grid.Row="2" Text="已分配"  Style="{StaticResource TextBlockStyle3}"/>
                            </Grid>
                        </Border>
                        <Border x:Name="Rack_3_1" Grid.Row="3" Grid.Column="1" Margin="3"
                            Background="Yellow" BorderBrush="Gray" BorderThickness="1" CornerRadius="3">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="17"  Style="{StaticResource TextBlockStyle1}"/>
                                <TextBlock Grid.Row="1" Text="料M"  Style="{StaticResource TextBlockStyle2}"/>
                                <TextBlock Grid.Row="2" Text="待分配"  Style="{StaticResource TextBlockStyle3}"/>
                            </Grid>
                        </Border>
                        <Border x:Name="Rack_3_2" Grid.Row="3" Grid.Column="2" Margin="3"
                            Background="Yellow" BorderBrush="Gray" BorderThickness="1" CornerRadius="3">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="18"  Style="{StaticResource TextBlockStyle1}"/>
                                <TextBlock Grid.Row="1" Text="料N"  Style="{StaticResource TextBlockStyle2}"/>
                                <TextBlock Grid.Row="2" Text="已分配"  Style="{StaticResource TextBlockStyle3}"/>
                            </Grid>
                        </Border>
                        <Border x:Name="Rack_3_3" Grid.Row="3" Grid.Column="3" Margin="3"
                            Background="Red" BorderBrush="Gray" BorderThickness="1" CornerRadius="3">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="19"  Style="{StaticResource TextBlockStyle1}"/>
                                <TextBlock Grid.Row="1" Text="空"  Style="{StaticResource TextBlockStyle2}"/>
                                <TextBlock Grid.Row="2" Text="待分配"  Style="{StaticResource TextBlockStyle3}"/>
                            </Grid>
                        </Border>
                        <Border x:Name="Rack_3_4" Grid.Row="3" Grid.Column="4" Margin="3"
                            Background="Yellow" BorderBrush="Gray" BorderThickness="1" CornerRadius="3">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="20"  Style="{StaticResource TextBlockStyle1}"/>
                                <TextBlock Grid.Row="1" Text="料O"  Style="{StaticResource TextBlockStyle2}"/>
                                <TextBlock Grid.Row="2" Text="已分配"  Style="{StaticResource TextBlockStyle3}"/>
                            </Grid>
                        </Border>

                        <!-- 第5行 -->
                        <Border x:Name="Rack_4_0" Grid.Row="4" Grid.Column="0" Margin="3"
                            Background="Yellow" BorderBrush="Gray" BorderThickness="1" CornerRadius="3">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="21"  Style="{StaticResource TextBlockStyle1}"/>
                                <TextBlock Grid.Row="1" Text="料P"  Style="{StaticResource TextBlockStyle2}"/>
                                <TextBlock Grid.Row="2" Text="待分配"  Style="{StaticResource TextBlockStyle3}"/>
                            </Grid>
                        </Border>
                        <Border x:Name="Rack_4_1" Grid.Row="4" Grid.Column="1" Margin="3"
                            Background="Red" BorderBrush="Gray" BorderThickness="1" CornerRadius="3">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="22"  Style="{StaticResource TextBlockStyle1}"/>
                                <TextBlock Grid.Row="1" Text="空"  Style="{StaticResource TextBlockStyle2}"/>
                                <TextBlock Grid.Row="2" Text="待分配"  Style="{StaticResource TextBlockStyle3}"/>
                            </Grid>
                        </Border>
                        <Border x:Name="Rack_4_2" Grid.Row="4" Grid.Column="2" Margin="3"
                            Background="Yellow" BorderBrush="Gray" BorderThickness="1" CornerRadius="3">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="23"  Style="{StaticResource TextBlockStyle1}"/>
                                <TextBlock Grid.Row="1" Text="料Q"  Style="{StaticResource TextBlockStyle2}"/>
                                <TextBlock Grid.Row="2" Text="已分配"  Style="{StaticResource TextBlockStyle3}"/>
                            </Grid>
                        </Border>
                        <Border x:Name="Rack_4_3" Grid.Row="4" Grid.Column="3" Margin="3"
                            Background="Yellow" BorderBrush="Gray" BorderThickness="1" CornerRadius="3">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="24"  Style="{StaticResource TextBlockStyle1}"/>
                                <TextBlock Grid.Row="1" Text="料R"  Style="{StaticResource TextBlockStyle2}"/>
                                <TextBlock Grid.Row="2" Text="已分配"  Style="{StaticResource TextBlockStyle3}"/>
                            </Grid>
                        </Border>
                        <Border x:Name="Rack_4_4" Grid.Row="4" Grid.Column="4" Margin="3"
                            Background="Yellow" BorderBrush="Gray" BorderThickness="1" CornerRadius="3">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="25"  Style="{StaticResource TextBlockStyle1}"/>
                                <TextBlock Grid.Row="1" Text="料S"  Style="{StaticResource TextBlockStyle2}"/>
                                <TextBlock Grid.Row="2" Text="待分配"  Style="{StaticResource TextBlockStyle3}"/>
                            </Grid>
                        </Border>
                    </Grid>
                </GroupBox>
            </Grid>

            <!-- 分隔线 -->
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                      Background="Gray" ShowsPreview="True" ResizeDirection="Columns"/>

            <!-- ===== 右侧：下拉框 + 刀具选择 + 按钮 ===== -->
            <Grid Grid.Column="2" Margin="5,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
