                            <Border Grid.Row="9" Grid.Column="2" Style="{StaticResource ToolCellBorderStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="2*"/>
                                        <RowDefinition Height="3*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="T30" Style="{StaticResource ToolLabelStyle}"/>
                                    <ComboBox Grid.Row="1" x:Name="Tool_9_2" Style="{StaticResource ToolComboBoxStyle}"/>
                                </Grid>
                            </Border>

                            <Border Grid.Row="9" Grid.Column="3" Style="{StaticResource ToolCellBorderStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="2*"/>
                                        <RowDefinition Height="3*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="T40" Style="{StaticResource ToolLabelStyle}"/>
                                    <ComboBox Grid.Row="1" x:Name="Tool_9_3" Style="{StaticResource ToolComboBoxStyle}"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </GroupBox>
                </Grid>

                <!-- 底部按钮行 -->
                <Grid Grid.Row="3" Margin="0,10,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="刀架刀具规格维护" Height="35" FontSize="28" Margin="0,0,10,0" Padding="10,0" Click="BtnToolMaintenance_Click"/>
                    <Button Grid.Column="1" Content="文件加载" Height="35" FontSize="28" HorizontalAlignment="Right" Width="240"/>
                </Grid>
            </Grid>
        </Grid>

        <!-- ===== 子页面容器（覆盖显示） ===== -->
        <Grid x:Name="SubPageContainer" 
              Background="#F5F5F5" 
              Opacity="0" 
              Visibility="Collapsed">
            <!-- 动态加载的子页面将放在这里 -->
        </Grid>
    </Grid>
</UserControl>