                    <ComboBoxItem Content="文件_002.nc"/>
                    <ComboBoxItem Content="文件_003.nc"/>
                    <ComboBoxItem Content="文件_004.nc"/>
                    <ComboBoxItem Content="文件_005.nc"/>
