<Window x:Class="WPF_test.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:pages="clr-namespace:WPF_test.Pages"
        mc:Ignorable="d"
        Title="MainWindow"
        WindowStyle="None"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#1E1E2E"
        SizeToContent="Manual">

    <Window.Resources>
        <!-- Tab 按钮样式 -->
        <Style x:Key="TabButtonStyle" TargetType="RadioButton">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#A6ADC8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="0,3,0,0"
                                CornerRadius="4"
                                Margin="3,2"
                                Padding="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#313244"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#89B4FA"/>
                                <Setter Property="Foreground" Value="#89B4FA"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#45475A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 状态标签样式 -->
        <Style x:Key="StatusLabelStyle" TargetType="Border">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="4,0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 顶部状态栏 -->
            <RowDefinition Height="Auto"/>
            <!-- 顶部栏：关闭按钮 -->
            <RowDefinition Height="*"/>
            <!-- 内容区域 -->
            <RowDefinition Height="Auto"/>
            <!-- 底部 Tab 栏 -->
        </Grid.RowDefinitions>

        <!-- ================================================================ -->
        <!-- 顶部状态栏：时间戳 + 状态 + 报警信息滚动 -->
        <!-- ================================================================ -->
        <Border Grid.Row="0" Background="#2D2D44" Height="60" BorderBrush="#313244" BorderThickness="0,0,0,1">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 时间戳 -->
                <TextBlock x:Name="TimeStamp" Grid.Column="0"
                           Text="2026/07/13 20:53:30 星期一"
                           FontSize="13" FontWeight="Bold"
                           Foreground="#CDD6F4"
                           VerticalAlignment="Center"
                           Margin="0,0,20,0"/>

                <!-- 状态标签 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Style="{StaticResource StatusLabelStyle}">
                        <TextBlock Text="无权限" Foreground="#A6ADC8" FontSize="12" FontWeight="Bold"/>
                    </Border>
                    <Border Style="{StaticResource StatusLabelStyle}" Background="#F9E2AF">
                        <TextBlock Text="手动中" Foreground="#1E1E2E" FontSize="12" FontWeight="Bold"/>
                    </Border>
                    <Border Style="{StaticResource StatusLabelStyle}">
                        <TextBlock Text="停止中" Foreground="#A6ADC8" FontSize="12" FontWeight="Bold"/>
                    </Border>
                </StackPanel>

                <!-- 滚动报警信息 -->
                <ScrollViewer Grid.Column="2" 
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Disabled"
                              Margin="20,0">
                    <TextBlock x:Name="AlarmScrollText"
                               Text="系统运行正常 | 无报警信息"
                               Foreground="#F38BA8"
                               FontSize="12"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               TextTrimming="None">
                        <TextBlock.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation 
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                            From="200" To="-800"
                                            Duration="0:0:10"
                                            RepeatBehavior="Forever"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </TextBlock.Triggers>
                        <TextBlock.RenderTransform>
                            <TranslateTransform X="0"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </ScrollViewer>

                <!-- 关闭按钮（保留，但移到状态栏最右侧） -->
                <Button Grid.Column="3" x:Name="BtnClose"
                        Width="36" Height="36"
                        FontSize="16" FontWeight="Bold"
                        Content="✕"
                        Foreground="#CDD6F4"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="BtnClose_Click"
                        Margin="0,0,0,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border"
                                                Background="{TemplateBinding Background}"
                                                BorderThickness="0">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#E81123"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <!-- ================================================================ -->
        <!-- 内容区域：所有页面叠加，Tab 切换显示 -->
        <!-- ================================================================ -->
        <Grid Grid.Row="2">
            <pages:MainPage           x:Name="Page_Main"      Visibility="Visible"/>
            <pages:ManualPage          x:Name="Page_Manual"    Visibility="Collapsed"/>
            <pages:RegisteredPage     x:Name="Page_Registered" Visibility="Collapsed"/>
            <pages:ProductionRecordPage x:Name="Page_Production" Visibility="Collapsed"/>
            <pages:AlarmRecordPage     x:Name="Page_AlarmRecord" Visibility="Collapsed"/>
            <pages:OtherPage          x:Name="Page_Other"     Visibility="Collapsed"/>
            <pages:AlmPage            x:Name="Page_Alm"       Visibility="Collapsed"/>
        </Grid>

        <!-- ================================================================ -->
        <!-- 底部 Tab 栏：8 个按钮（7 页面切换 + 1 故障解除） -->
        <!-- ================================================================ -->
        <Border Grid.Row="3" Background="#181825" BorderBrush="#313244" BorderThickness="0,1,0,0">
            <Grid Height="80" Margin="8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Tab: 主页面 -->
                <RadioButton x:Name="Tab_Main" Grid.Column="0"
                             Content="主页面" IsChecked="True"
                             Click="TabPage_Click"
                             Tag="Main"
                             Style="{StaticResource TabButtonStyle}"/>

                <!-- Tab: 手动页面 -->
                <RadioButton x:Name="Tab_Manual" Grid.Column="1"
                             Content="手动页面"
                             Click="TabPage_Click"
                             Tag="Manual"
                             Style="{StaticResource TabButtonStyle}"/>

                <!-- Tab: 在籍页面 -->
                <RadioButton x:Name="Tab_Registered" Grid.Column="2"
                             Content="在籍页面"
                             Click="TabPage_Click"
                             Tag="Registered"
                             Style="{StaticResource TabButtonStyle}"/>

                <!-- Tab: 生产记录 -->
                <RadioButton x:Name="Tab_Production" Grid.Column="3"
                             Content="生产记录"
                             Click="TabPage_Click"
                             Tag="Production"
                             Style="{StaticResource TabButtonStyle}"/>

                <!-- Tab: 报警记录 -->
                <RadioButton x:Name="Tab_AlarmRecord" Grid.Column="4"
                             Content="报警记录"
                             Click="TabPage_Click"
                             Tag="AlarmRecord"
                             Style="{StaticResource TabButtonStyle}"/>

                <!-- Tab: 其他 -->
                <RadioButton x:Name="Tab_Other" Grid.Column="5"
                             Content="其他"
                             Click="TabPage_Click"
                             Tag="Other"
                             Style="{StaticResource TabButtonStyle}"/>

                <!-- Tab: ALM -->
                <RadioButton x:Name="Tab_Alm" Grid.Column="6"
                             Content="ALM"
                             Click="TabPage_Click"
                             Tag="Alm"
                             Style="{StaticResource TabButtonStyle}"/>

                <!-- Tab: 故障解除（不切换页面，仅触发事件） -->
                <Button x:Name="Tab_FaultReset" Grid.Column="7"
                        Content="故障解除"
                        Click="Tab_FaultReset_Click"
                        FontSize="14" FontWeight="Bold"
                        Foreground="#F38BA8"
                        Background="#313244"
                        BorderThickness="1"
                        BorderBrush="#45475A"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4"
                                    Margin="3">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#F38BA8"/>
                                    <Setter TargetName="border" Property="BorderBrush" Value="#F38BA8"/>
                                    <Setter Property="Foreground" Value="#1E1E2E"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>