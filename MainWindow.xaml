<Window x:Class="WPF_test.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:pages="clr-namespace:WPF_test.Pages"
        mc:Ignorable="d"
        Title="MainWindow"
        WindowStyle="None"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#1E1E2E">

    <Window.Resources>
        <!-- Tab 按钮样式 -->
        <Style x:Key="TabButtonStyle" TargetType="RadioButton">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#A6ADC8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="0,3,0,0"
                                CornerRadius="4"
                                Margin="3,2"
                                Padding="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#313244"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#89B4FA"/>
                                <Setter Property="Foreground" Value="#89B4FA"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#45475A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- 背景色透明层 -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 顶部栏：关闭按钮 -->
            <RowDefinition Height="*"/>      <!-- 内容区域 -->
            <RowDefinition Height="Auto"/>   <!-- 底部 Tab 栏 -->
        </Grid.RowDefinitions>

        <!-- ================================================================ -->
        <!-- 顶部栏：项目标题 + 关闭按钮 -->
        <!-- ================================================================ -->
        <Grid Grid.Row="0" Background="#2D2D44" Height="38">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 标题 -->
            <TextBlock Grid.Column="0" Text="CNC 加工中心控制系统"
                       FontSize="15" FontWeight="Bold" Foreground="#CDD6F4"
                       VerticalAlignment="Center" Margin="12,0,0,0"/>

            <!-- 关闭按钮 X -->
            <Button Grid.Column="1" x:Name="BtnClose"
                    Width="38" Height="38"
                    FontSize="16" FontWeight="Bold"
                    Content="✕"
                    Foreground="#CDD6F4"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="BtnClose_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border"
                                            Background="{TemplateBinding Background}"
                                            BorderThickness="0">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#E81123"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

        <!-- ================================================================ -->
        <!-- 内容区域：所有页面叠加，Tab 切换显示 -->
        <!-- ================================================================ -->
        <Grid Grid.Row="1">
            <pages:MainPage           x:Name="Page_Main"      Visibility="Visible"/>
            <pages:ManualPage          x:Name="Page_Manual"    Visibility="Collapsed"/>
            <pages:RegisteredPage     x:Name="Page_Registered" Visibility="Collapsed"/>
            <pages:ProductionRecordPage x:Name="Page_Production" Visibility="Collapsed"/>
            <pages:AlarmRecordPage     x:Name="Page_AlarmRecord" Visibility="Collapsed"/>
            <pages:OtherPage          x:Name="Page_Other"     Visibility="Collapsed"/>
            <pages:AlmPage            x:Name="Page_Alm"       Visibility="Collapsed"/>
        </Grid>

        <!-- ================================================================ -->
        <!-- 底部 Tab 栏：8 个按钮（7 页面切换 + 1 故障解除） -->
        <!-- ================================================================ -->
        <Border Grid.Row="2" Background="#181825" BorderBrush="#313244" BorderThickness="0,1,0,0">
            <Grid Height="52" Margin="8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Tab: 主页面 -->
                <RadioButton x:Name="Tab_Main" Grid.Column="0"
                             Content="主页面" IsChecked="True"
                             Click="TabPage_Click"
                             Tag="Main"
                             Style="{StaticResource TabButtonStyle}"/>

                <!-- Tab: 手动页面 -->
                <RadioButton x:Name="Tab_Manual" Grid.Column="1"
                             Content="手动页面"
                             Click="TabPage_Click"
                             Tag="Manual"
                             Style="{StaticResource TabButtonStyle}"/>

                <!-- Tab: 在籍页面 -->
                <RadioButton x:Name="Tab_Registered" Grid.Column="2"
                             Content="在籍页面"
                             Click="TabPage_Click"
                             Tag="Registered"
                             Style="{StaticResource TabButtonStyle}"/>

                <!-- Tab: 生产记录 -->
                <RadioButton x:Name="Tab_Production" Grid.Column="3"
                             Content="生产记录"
                             Click="TabPage_Click"
                             Tag="Production"
                             Style="{StaticResource TabButtonStyle}"/>

                <!-- Tab: 报警记录 -->
                <RadioButton x:Name="Tab_AlarmRecord" Grid.Column="4"
                             Content="报警记录"
                             Click="TabPage_Click"
                             Tag="AlarmRecord"
                             Style="{StaticResource TabButtonStyle}"/>

                <!-- Tab: 其他 -->
                <RadioButton x:Name="Tab_Other" Grid.Column="5"
                             Content="其他"
                             Click="TabPage_Click"
                             Tag="Other"
                             Style="{StaticResource TabButtonStyle}"/>

                <!-- Tab: ALM -->
                <RadioButton x:Name="Tab_Alm" Grid.Column="6"
                             Content="ALM"
                             Click="TabPage_Click"
                             Tag="Alm"
                             Style="{StaticResource TabButtonStyle}"/>

                <!-- Tab: 故障解除（不切换页面，仅触发事件） -->
                <Button x:Name="Tab_FaultReset" Grid.Column="7"
                        Content="故障解除"
                        Click="Tab_FaultReset_Click"
                        FontSize="14" FontWeight="Bold"
                        Foreground="#F38BA8"
                        Background="#313244"
                        BorderThickness="1"
                        BorderBrush="#45475A"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4"
                                    Margin="3">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#F38BA8"/>
                                    <Setter TargetName="border" Property="BorderBrush" Value="#F38BA8"/>
                                    <Setter Property="Foreground" Value="#1E1E2E"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
